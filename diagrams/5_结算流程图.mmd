flowchart TD
  Start(["管理员发起结算"]) --> P{"是否为管理员"}
  P -- "否" --> P1["拒绝：仅管理员可结算"]
  P1 --> End1(["结束"])
  P -- "是" --> Q{"订单是否已完成"}
  Q -- "是" --> Q1["拦截：已结算订单不可重复操作"]
  Q1 --> End1
  Q -- "否" --> B["录入物料清点结果，逐条核对<br/>损耗 = 准备量 减 清点量，回补库存并写入损耗表"]
  B --> G["损耗合计 = 物料损耗 + 额外损耗<br/>营收 = 实收　成本 = 损耗合计<br/>利润 = 实收 减 损耗合计（帮厨费转付，不计入利润）"]
  G --> H["写入或更新结算表，订单状态置为 已完成"]
  H --> End(["进入统计分析"])
