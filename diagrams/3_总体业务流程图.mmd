flowchart TD
  Start(["客户咨询"]) --> A["录入或选择客户"]
  A --> B["创建宴席订单<br/>日期 / 桌数 / 类型"]
  B --> C{"当天是否已有未取消订单"}
  C -- "是（提示档期冲突）" --> C1["经营者改期"]
  C1 --> B
  C -- "否" --> D["确定菜单<br/>套餐 / 菜品"]
  D --> E["准备物料<br/>按需扣减库存"]
  E --> F["安排帮厨人工"]
  F --> G["宴席执行"]
  G --> H{"是否有临时变更"}
  H -- "是" --> H1["记录变更"]
  H1 --> G
  H -- "否" --> I["宴后清点物料<br/>计算损耗"]
  I --> J["订单结算<br/>实收 / 损耗 / 利润"]
  J --> K["统计分析"]
  K --> End(["完成"])
